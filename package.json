{
  "name": "anima-toolbox",
  "version": "0.1.0",
  "description": "Desktop toolbox for the Anima model: XY plot grids via ComfyUI + Camie-Tagger v2 batch tagging",
  "repository": {
    "type": "git",
    "url": "https://github.com/Lambda-D3L7A/anima-toolbox.git"
  },
  "homepage": "https://github.com/Lambda-D3L7A/anima-toolbox",
  "bugs": "https://github.com/Lambda-D3L7A/anima-toolbox/issues",
  "keywords": ["anima", "comfyui", "lora", "xy-plot", "electron", "tagger", "danbooru", "onnx"],
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "author": "Lambda-D3L7A",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "onnxruntime-node": "^1.20.1",
    "sharp": "^0.33.5",
    "ws": "^8.18.0"
  },
  "build": {
    "appId": "com.lambda.anima-toolbox",
    "productName": "Anima Toolbox",
    "artifactName": "${name}-${version}-setup.${ext}",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
