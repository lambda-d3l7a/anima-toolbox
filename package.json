{
  "name": "anima-xy-plot",
  "version": "0.1.0",
  "description": "Generate XY plot grids for the Anima model and its LoRAs via ComfyUI",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "author": "Lambda-D3L7A",
  "license": "MIT",
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "onnxruntime-node": "^1.20.1",
    "sharp": "^0.33.5",
    "ws": "^8.18.0"
  },
  "build": {
    "appId": "com.lambda.anima-xy-plot",
    "productName": "Anima XY Plot",
    "artifactName": "${name}-${version}-setup.${ext}",
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
